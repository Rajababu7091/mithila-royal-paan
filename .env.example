# ============================================================
# MITHILA ROYAL PAAN - Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to:  .env
#   2. Fill in your actual values below
#   3. NEVER commit the .env file to Git (it is already in .gitignore)
# ============================================================

# --- Database (Railway MySQL) ---
# Get these from: railway.app > Your Project > MySQL Service > Variables tab
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_NAME=railway
DB_USERNAME=root
DB_PASSWORD=your_railway_mysql_password

# --- Google OAuth2 (optional) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- JWT Secret ---
JWT_SECRET=MithilaRoyalPaanPremiumSecretKeyForJWTTokenAuthService123!

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key
