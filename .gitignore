# =============================================
# Maven Wrapper — MUST be committed to Git
# DO NOT ignore mvnw, mvnw.cmd, or .mvn/
# =============================================
!backend/mvnw
!backend/mvnw.cmd
!backend/.mvn/
!backend/.mvn/wrapper/
!backend/.mvn/wrapper/maven-wrapper.properties

# Commit the wrapper JAR so Render/Railway can build without network access
!backend/.mvn/wrapper/maven-wrapper.jar
