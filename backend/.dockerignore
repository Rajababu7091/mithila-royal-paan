# ============================================================
# Docker ignore file for MITHILA ROYAL PAAN backend
# Keeps the Docker build context lean and fast
# ============================================================

# Git
.git
.gitignore

# IDE / Editor files
.idea
.vscode
*.iml
*.iws

# Maven build output (rebuilt inside Docker)
target/

# Local environment / secrets
.env
*.env

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test reports
surefire-reports/

# Uploaded files (runtime data, not source)
uploads/

# Documentation
docs/
README.md

# Frontend (served separately or via static-locations)
../frontend/
